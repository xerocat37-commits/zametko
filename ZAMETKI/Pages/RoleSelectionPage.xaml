<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ZAMETKI.Pages.RoleSelectionPage"
             Title="Регистрация">
    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center" MaximumWidthRequest="420">

            <Label Text="Кто вы?" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="Выберите свою роль для регистрации" FontSize="14" HorizontalOptions="Center" Margin="0,0,0,16" />

            <Button Text="Студент" Clicked="OnStudentClicked" />
            <Button Text="Преподаватель" Clicked="OnTeacherClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
