<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZAMETKI.ViewModels"
             xmlns:editor="clr-namespace:ZAMETKI.Editor.Views"
             x:Class="ZAMETKI.Pages.PersonalNoteEditorPage"
             x:DataType="vm:PersonalNoteEditorViewModel"
             Title="Заметка">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="8">

        <Entry Grid.Row="0" Placeholder="Заголовок" Text="{Binding Title}" />

        <editor:NoteEditorView Grid.Row="1" BindingContext="{Binding Editor}" />

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Label Text="{Binding ErrorMessage}" TextColor="Red" />
            <Button Text="Сохранить" Command="{Binding SaveCommand}" IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
