<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZAMETKI.ViewModels"
             x:Class="ZAMETKI.Pages.GroupNoteEditorPage"
             x:DataType="vm:GroupNoteEditorViewModel"
             Title="Новая заметка группы">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Entry Placeholder="Заголовок" Text="{Binding Title}" />
            <Editor Placeholder="Текст заметки..." Text="{Binding Content}" AutoSize="TextChanges" HeightRequest="200" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" />

            <Button Text="Сохранить" Command="{Binding SaveCommand}" IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
