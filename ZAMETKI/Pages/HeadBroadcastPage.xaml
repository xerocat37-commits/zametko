<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:contracts="clr-namespace:ZAMETKI.Api.Contracts"
             xmlns:vm="clr-namespace:ZAMETKI.ViewModels"
             xmlns:editor="clr-namespace:ZAMETKI.Editor.Views"
             x:Class="ZAMETKI.Pages.HeadBroadcastPage"
             x:DataType="vm:HeadBroadcastViewModel"
             Title="Рассылка">

    <Grid Padding="16" RowSpacing="8"
          RowDefinitions="Auto,Auto,300,Auto,Auto,Auto,*">

        <Label Grid.Row="0" Text="Новая рассылка" FontSize="18" FontAttributes="Bold" />
        <Entry Grid.Row="1" Placeholder="Заголовок" Text="{Binding NewTitle}" />

        <editor:NoteEditorView Grid.Row="2" BindingContext="{Binding Editor}" />

        <Label Grid.Row="3" Text="{Binding ErrorMessage}" TextColor="Red" />
        <Button Grid.Row="4" Text="Разослать всем" Command="{Binding CreateCommand}" IsEnabled="{Binding IsNotBusy}" />
        <ActivityIndicator Grid.Row="4" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="End" />

        <Label Grid.Row="5" Text="История рассылок" FontSize="18" FontAttributes="Bold" Margin="0,16,0,4" />

        <CollectionView Grid.Row="6" ItemsSource="{Binding Broadcasts}" SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="Рассылок ещё не было" TextColor="Gray" HorizontalOptions="Center" Padding="0,12,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="contracts:NoteDto">
                    <Border Margin="0,4" Padding="12" BackgroundColor="#F5F5F5" Stroke="#E0E0E0" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto,Auto,Auto">
                            <Label Grid.Row="0" Text="{Binding Title}" FontSize="16" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="{Binding Content, Converter={StaticResource BlockPreview}}"
                                   FontSize="13" TextColor="#444" Margin="0,4,0,0" />
                            <Label Grid.Row="2" Text="{Binding CreatedDate, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                   FontSize="11" TextColor="Gray" Margin="0,4,0,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
