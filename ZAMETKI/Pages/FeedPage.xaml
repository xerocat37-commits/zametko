<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:contracts="clr-namespace:ZAMETKI.Api.Contracts"
             xmlns:vm="clr-namespace:ZAMETKI.ViewModels"
             x:Class="ZAMETKI.Pages.FeedPage"
             x:DataType="vm:FeedViewModel"
             Title="Лента">

    <Grid RowDefinitions="*,Auto" Padding="10">
        <RefreshView Grid.Row="0" Refreshing="RefreshView_Refreshing" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Feed}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                        <Label Text="📭" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="Лента пуста" FontSize="18" HorizontalOptions="Center" Margin="0,10,0,0" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="contracts:NoteDto">
                        <Border Margin="5" Padding="15" Stroke="#E0E0E0" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                <Label Grid.Row="0" Text="{Binding NoteType}" FontSize="11" FontAttributes="Bold" TextColor="#007AFF" />
                                <Label Grid.Row="1" Text="{Binding Title}" FontSize="18" FontAttributes="Bold" Margin="0,5,0,0" />
                                <Label Grid.Row="2" Text="{Binding Content, Converter={StaticResource BlockPreview}}" FontSize="14" TextColor="#444" Margin="0,5,0,0" />
                                <Label Grid.Row="3" Text="{Binding CreatedDate, StringFormat='{0:dd.MM.yyyy HH:mm}'}" FontSize="12" TextColor="Gray" Margin="0,5,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
