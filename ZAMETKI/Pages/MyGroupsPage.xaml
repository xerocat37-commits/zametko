<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:contracts="clr-namespace:ZAMETKI.Api.Contracts"
             xmlns:vm="clr-namespace:ZAMETKI.ViewModels"
             x:Class="ZAMETKI.Pages.MyGroupsPage"
             x:DataType="vm:MyGroupsViewModel"
             Title="Мои группы">

    <Grid RowDefinitions="*,Auto" Padding="10">

        <RefreshView Grid.Row="0" IsRefreshing="{Binding IsBusy}" Refreshing="RefreshView_Refreshing">
            <CollectionView ItemsSource="{Binding Groups}"
                            SelectionMode="Single"
                            SelectionChanged="GroupsCollectionView_SelectionChanged">
                <CollectionView.EmptyView>
                    <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                        <Label Text="👥" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="Нет групп" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10,0,5" />
                        <Label Text="Нажмите '+' чтобы создать первую группу" FontSize="14" TextColor="Gray" HorizontalOptions="Center" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="contracts:GroupDto">
                        <Border Margin="5" Padding="15" BackgroundColor="#F5F5F5" Stroke="#E0E0E0" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Grid RowDefinitions="Auto,Auto">
                                <Label Grid.Row="0" Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#333" />
                                <Label Grid.Row="1" Text="{Binding CreatedDate, StringFormat='создана {0:dd.MM.yyyy}'}" FontSize="12" TextColor="Gray" Margin="0,5,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="1"
                Text="+ Новая группа"
                FontSize="18"
                FontAttributes="Bold"
                BackgroundColor="#007AFF"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"
                Margin="0,10,0,0"
                Clicked="AddGroupButton_Clicked" />
    </Grid>
</ContentPage>
